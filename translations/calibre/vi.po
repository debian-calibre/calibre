#: /__w/calibre/calibre/src/calibre/debug.py:33
#, python-brace-format
msgid ""
"{0}\n"
"\n"
"Various command line interfaces useful for debugging calibre. With no options,\n"
"this command starts an embedded Python interpreter. You can also run the main\n"
"calibre GUI, the calibre E-book viewer and the calibre editor in debug mode.\n"
"\n"
"It also contains interfaces to various bits of calibre that do not have\n"
"dedicated command line tools, such as font subsetting, the E-book diff tool and so\n"
"on.\n"
"\n"
"You can also use %prog to run standalone scripts. To do that use it like this:\n"
"\n"
"    {1}\n"
"\n"
"Everything after the -- is passed to the script. You can also use calibre-debug\n"
"as a shebang in scripts, like this:\n"
"\n"
"    {2}\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:52
msgid "%prog [options]"
msgstr "%prog [options]"

#: /__w/calibre/calibre/src/calibre/debug.py:53
msgid "Run Python code."
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:54
msgid "Run the Python code in file."
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:56
msgid ""
"Subset the specified font. Use -- after this option to pass option to the "
"font subsetting program."
msgstr "Subset font đã định. Bạn có thể dùng -- sau tùynày để một chương trình subset font chữ khác có thể nhận được tùy chọn từ calibre."

#: /__w/calibre/calibre/src/calibre/debug.py:58
#: /__w/calibre/calibre/src/calibre/gui2/device.py:538
#: /__w/calibre/calibre/src/calibre/gui2/preferences/device_debug.py:26
msgid "Debug device detection"
msgstr "Gỡ lỗi cho quá trình tìm thiết bị"

#: /__w/calibre/calibre/src/calibre/debug.py:60
msgid ""
"Run the GUI with debugging enabled. Debug output is printed to stdout and "
"stderr. To pass command line arguments use -- followed by the arguments, for"
" example: calibre-debug -g -- /path/to/ebook"
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:65
msgid ""
"Run the GUI with a debug console, logging to the specified path. For "
"internal use only, use the -g option to run the GUI in debug mode"
msgstr "Chạy chương trình với debug console và ghi log vào một đường dẫn nhất định. Chỉ dùng cho  nội bộ. Dùng cú pháp -g để chạy chương trình trong chế độ sửa lỗi."

#: /__w/calibre/calibre/src/calibre/debug.py:68
msgid "Don't run with the DEBUG flag set"
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:70
msgid ""
"Run the E-book viewer in debug mode. As with -g use -- to pass command line "
"arguments."
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:72
msgid "Output the paths necessary to setup the calibre environment"
msgstr "Tạo đầu ra các đường dẫn cần để thiết lập calibre"

#: /__w/calibre/calibre/src/calibre/debug.py:74
msgid ""
"Add a simple plugin (i.e. a plugin that consists of only a .py file), by "
"specifying the path to the py file containing the plugin code."
msgstr "Thêm một plugin đơn giản (vd như một plugin có một file .py duy nhất) bằng cách trỏ đường dẫn đến file py chứa code cho plugin."

#: /__w/calibre/calibre/src/calibre/debug.py:79
msgid "Inspect the MOBI file(s) at the specified path(s)"
msgstr "Kiểm tra file MOBI tại các đường dẫn đã định"

#: /__w/calibre/calibre/src/calibre/debug.py:81
msgid ""
"Launch the calibre \"Edit book\" tool in debug mode. As with -g use -- to "
"pass command line arguments."
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:83
msgid ""
"Explode the book into the specified folder.\n"
"Usage: -x file.epub output_dir\n"
"Exports the book as a collection of HTML files and metadata, which you can edit using standard HTML editing tools. Works with EPUB, AZW3, HTMLZ and DOCX files."
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:89
msgid ""
"Implode a previously exploded book.\n"
"Usage: -i output_dir file.epub\n"
"Imports the book from the files in output_dir which must have been created by a previous call to --explode-book. Be sure to specify the same file type as was used when exploding."
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:94
msgid ""
"Export all calibre data (books/settings/plugins). Normally, you will be asked for the export folder and the libraries to export. You can also specify them as command line arguments to skip the questions. Use absolute paths for the export folder and libraries. The special keyword \"all\" can be used to export all libraries. Examples:\n"
"\n"
"  calibre-debug --export-all-calibre-data  # for interactive use\n"
"  calibre-debug --export-all-calibre-data /path/to/empty/export/folder /path/to/library/folder1 /path/to/library2\n"
"  calibre-debug --export-all-calibre-data /export/folder all  # export all known libraries"
msgstr ""

#: /__w/calibre/calibre/src/calibre/debug.py:104
msgid "Import previously exported calibre data"
msgstr "Nhập dữ liệu calibre đã xuất trước đó"

#: /__w/calibre/calibre/src/calibre/debug.py:107
#: /__w/calibre/calibre/src/calibre/gui2/main.py:63
msgid ""
"Cause a running calibre instance, if any, to be shutdown. Note that if there"
" are running jobs, they will be silently aborted, so use with care."
msgstr "Khiến bản calibre đang thực thi có thể kết thúc. Lưu ý rằng nếu có tác vụ đang thực thi, chúng sẽ được âm thầm hủy bỏ , do đó, sử dụng cẩn thận."

#: /__w/calibre/calibre/src/calibre/debug.py:110
msgid "Test binary modules in build"
msgstr "Thử nghiệm các module nhị phân "

#: /__w/calibre/calibre/src/calibre/debug.py:113
msgid ""
"Run a plugin that provides a command line interface. For example:\n"
