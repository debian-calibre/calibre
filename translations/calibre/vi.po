#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:57
#, python-format, python-brace-format
msgid ""
"<p><i>Polishing books</i> is all about putting the shine of perfection onto\n"
"your carefully crafted e-books.</p>\n"
"\n"
"<p>Polishing tries to minimize the changes to the internal code of your e-book.\n"
"Unlike conversion, it <i>does not</i> flatten CSS, rename files, change font\n"
"sizes, adjust margins, etc. Every action performs only the minimum set of\n"
"changes needed for the desired effect.</p>\n"
"\n"
"<p>You should use this tool as the last step in your e-book creation process.</p>\n"
"{0}\n"
"<p>Note that polishing only works on files in the %s formats.</p>"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:69
#: /__w/calibre/calibre/src/calibre/gui2/actions/polish.py:498
#: /__w/calibre/calibre/src/calibre/gui2/actions/toc_edit.py:98
#: /__w/calibre/calibre/src/calibre/gui2/actions/tweak_epub.py:108
#: /__w/calibre/calibre/src/calibre/gui2/viewer/search.py:600
#: /__w/calibre/calibre/src/calibre/gui2/viewer/ui.py:777
msgid " or "
msgstr "hoặc"

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:71
msgid ""
"<p>Embed all fonts that are referenced in the document and are not already embedded.\n"
"This will scan your computer for the fonts, and if they are found, they will be\n"
"embedded into the document.</p>\n"
"<p>Please ensure that you have the proper license for embedding the fonts used in this document.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:78
msgid ""
"<p>Subsetting fonts means reducing an embedded font to contain\n"
"only the characters used from that font in the book. This\n"
"greatly reduces the size of the font files (halving the font\n"
"file sizes is common).</p>\n"
"\n"
"<p>For example, if the book uses a specific font for headers,\n"
"then subsetting will reduce that font to contain only the\n"
"characters present in the actual headers in the book. Or if the\n"
"book embeds the bold and italic versions of a font, but bold\n"
"and italic text is relatively rare, or absent altogether, then\n"
"the bold and italic fonts can either be reduced to only a few\n"
"characters or completely removed.</p>\n"
"\n"
"<p>The only downside to subsetting fonts is that if, at a later\n"
"date you decide to add more text to your books, the newly added\n"
"text might not be covered by the subset font.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:97
msgid ""
"<p>Insert a \"book jacket\" page at the start of the book that contains\n"
"all the book metadata such as title, tags, authors, series, comments,\n"
"etc. Any previous book jacket will be replaced.</p>"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:102
msgid "<p>Remove a previous inserted book jacket page.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:106
msgid ""
"<p>Convert plain text dashes, ellipsis, quotes, multiple hyphens, etc. into their\n"
"typographically correct equivalents.</p>\n"
"<p>Note that the algorithm can sometimes generate incorrect results, especially\n"
"when single quotes at the start of contractions are involved.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:113
msgid ""
"<p>Remove all unused CSS rules from stylesheets and &lt;style&gt; tags. Some books\n"
"created from production templates can have a large number of extra CSS rules\n"
"that don't match any actual content. These extra rules can slow down readers\n"
"that need to parse them all.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:120
msgid ""
"<p>Losslessly compress images in the book, to reduce the filesize, without\n"
"affecting image quality.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:125
msgid ""
"<p>Upgrade the internal structures of the book, if possible. For instance,\n"
"upgrades EPUB 2 books to EPUB 3 books.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:130
msgid ""
"<p>Add soft hyphens to all words in the book. This allows the book to be rendered\n"
"better when the text is justified, in readers that do not support hyphenation.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:135
msgid "<p>Remove soft hyphens from all text in the book.</p>\n"
msgstr ""

#: /__w/calibre/calibre/src/calibre/ebooks/oeb/polish/main.py:139
msgid ""
"<p>Download external resources such as images, stylesheets, etc. that point to URLs instead of files in the book.\n"
"All such resources will be downloaded and added to the book so that the book no longer references any external resources.\n"
"</p>\n"
msgstr ""

