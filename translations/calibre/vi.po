#: /__w/calibre/calibre/src/calibre/srv/opts.py:68
msgid "Number of worker threads used to process requests"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:72
msgid "Maximum number of worker processes"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:74
msgid ""
"Worker processes are launched as needed and used for large jobs such as "
"preparing a book for viewing, adding books, converting, etc. Normally, the "
"max. number of such processes is based on the number of CPU cores. You can "
"control it by this setting."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:79
msgid "Maximum time for worker processes"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:81
msgid ""
"Maximum amount of time worker processes are allowed to run (in minutes). Set"
" to zero for no limit."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:84
msgid "The port on which to listen for connections"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:88
msgid "A prefix to prepend to all URLs"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:90
msgid ""
"Useful if you wish to run this server behind a reverse proxy. For example "
"use, /calibre as the URL prefix."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:92
msgid "Number of books to show in a single page"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:94
msgid "The number of books to show in a single page in the browser."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:96
msgid "Advertise OPDS feeds via BonJour"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:98
msgid ""
"Advertise the OPDS feeds via the BonJour service, so that OPDS based reading"
" apps can detect and connect to the server automatically."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:101
msgid "Maximum number of books in OPDS feeds"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:103
msgid ""
"The maximum number of books that the server will return in a single OPDS "
"acquisition feed."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:106
msgid "Maximum number of ungrouped items in OPDS feeds"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:108
msgid ""
"Group items in categories such as author/tags by first letter when there are"
" more than this number of items. Set to zero to disable."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:111
msgid "The interface on which to listen for connections"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:113
msgid ""
"The default is to listen on all available IPv6 and IPv4 interfaces. You can "
"change this to, for example, \"127.0.0.1\" to only listen for IPv4 "
"connections from the local machine, or to \"0.0.0.0\" to listen to all "
"incoming IPv4 connections."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:117
msgid "Fallback to auto-detected interface"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:119
msgid ""
"If for some reason the server is unable to bind to the interface specified "
"in the listen_on option, then it will try to detect an interface that "
"connects to the outside world and bind to that."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:123
msgid "Zero copy file transfers for increased performance"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:125
msgid ""
"This will use zero-copy in-kernel transfers when sending files over the "
"network, increasing performance. However, it can cause corrupted file "
"transfers on some broken filesystems. If you experience corrupted file "
"transfers, turn it off."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:129
msgid "Max. log file size (in MB)"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:131
msgid ""
"The maximum size of log files, generated by the server. When the log becomes"
" larger than this size, it is automatically rotated. Set to zero to disable "
"log rotation."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:134
msgid "Log HTTP 404 (Not Found) requests"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:136
msgid ""
"Normally, the server logs all HTTP requests for resources that are not "
"found. This can generate a lot of log spam, if your server is targeted by "
"bots. Use this option to turn it off."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:140
msgid "Password based authentication to access the server"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:142
msgid ""
"Normally, the server is unrestricted, allowing anyone to access it. You can "
"restrict access to predefined users with this option."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:145
msgid "Allow un-authenticated local connections to make changes"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:147
msgid ""
"Normally, if you do not turn on authentication, the server operates in read-"
"only mode, so as to not allow anonymous users to make changes to your "
"calibre libraries. This option allows anybody connecting from the same "
"computer as the server is running on to make changes. This is useful if you "
"want to run the server without authentication but still use calibredb to "
"make changes to your calibre libraries. Note that turning on this option "
"means any program running on the computer can make changes to your calibre "
"libraries. In particular, the Firefox web browser allows arbitrary websites "
"to do so as well."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:157
msgid ""
"Allow un-authenticated connections from specific IP addresses to make "
"changes"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:159
msgid ""
"Normally, if you do not turn on authentication, the server operates in read-"
"only mode, so as to not allow anonymous users to make changes to your "
"calibre libraries. This option allows anybody connecting from the specified "
"IP addresses to make changes. Must be a comma separated list of address or "
"network specifications. This is useful if you want to run the server without"
" authentication but still use calibredb to make changes to your calibre "
"libraries. Note that turning on this option means anyone connecting from the"
" specified IP addresses can make changes to your calibre libraries."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:168
msgid "Path to user database"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:170
msgid ""
"Path to a file in which to store the user and password information. Normally"
" a file in the calibre configuration folder is used."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:173
msgid "Choose the type of authentication used"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:174
msgid ""
"Set the HTTP authentication mode used by the server. Set to \"basic\" if you"
" are putting this server behind an SSL proxy. Otherwise, leave it as "
"\"auto\", which will use \"basic\" if SSL is configured otherwise it will "
"use \"digest\"."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:178
msgid "Ban IP addresses that have repeated login failures"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:179
msgid ""
"Temporarily bans access for IP addresses that have repeated login failures "
"for the specified number of minutes. Useful to prevent attempts at guessing "
"passwords. If set to zero, no banning is done."
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:183
msgid "Number of login failures for ban"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:184
msgid "The number of login failures after which an IP address is banned"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:186
msgid "Ignored user-defined metadata fields"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:188
#, python-brace-format
msgid ""
"Comma separated list of user-defined metadata fields that will not be "
"displayed by the Content server in the /opds and /mobile views. For example:"
" {}"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:192
msgid "Restrict displayed user-defined fields"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:194
#, python-brace-format
msgid ""
"Comma separated list of user-defined metadata fields that will be displayed "
"by the Content server in the /opds and /mobile views. If you specify this "
"option, any fields not in this list will not be displayed. For example: {}"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:199
msgid "Choose the default book list mode"
msgstr ""

#: /__w/calibre/calibre/src/calibre/srv/opts.py:201
msgid ""
