#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:646
msgid "Upload covers"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:654
msgid ""
"Upload cover images from the calibre library when sending books to the "
"device."
msgstr "Tải lên các hình ảnh bìa sách từ phần thư viện calibre khi đang thực hiện thao tác chuyển sách vào thiết bị."

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:658
msgid "Convert covers to grayscale when uploading."
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:663
msgid "Upload dithered covers"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:664
msgid ""
"Dither cover images to the appropriate 16c grayscale palette for an eInk "
"screen. This usually ensures greater accuracy and avoids banding, making "
"sleep covers look better. On FW >= 4.11, Nickel itself may sometimes do a "
"decent job of it. Has no effect without \"Upload black and white covers\"!"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:678
msgid "Keep cover aspect ratio"
msgstr "Giữ tỉ lệ hiển thị bìa sách"

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:679
msgid ""
"When uploading covers, do not change the aspect ratio when resizing for the "
"device. This is for firmware versions 2.3.1 and later."
msgstr "Khi đang tải lên các bìa sách, không thay đổi tỉ lệ hiển thị khi tiến hành chỉnh lại kích thước để hiển thị trong thiết bị. Phần này yêu cầu phần nhúng phải có phiên bản 2.3.1 hoặc mới hơn."

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:684
msgid "Letterbox full-screen covers"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:685
msgid ""
"Do it on our end, instead of letting Nickel handle it. Provides pixel-"
"perfect results on devices where Nickel does not do extra processing. "
"Obviously has no effect without \"Keep cover aspect ratio\". This is "
"probably undesirable if you disable the \"Show book covers full screen\" "
"setting on your device."
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:693
msgid ""
"Choose the color to use when letterboxing the cover. The default color is "
"black (#000000)"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:708
msgid "Save covers as PNG"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:709
msgid ""
"Use the PNG image format instead of JPG. Higher quality, especially with "
"\"Upload dithered covers\" enabled, which will also help generate "
"potentially smaller files. Behavior completely unknown on old (< 3.x) Kobo "
"firmwares, known to behave on FW >= 4.8. Has no effect without \"Upload "
"black and white covers\"!"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:765
msgid "Show as on device"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:773
msgid ""
"Kobo shows recommendations on the device.  In some cases these have files "
"but in other cases they are just pointers to the web site to buy. Enable if "
"you wish to see/delete them."
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:780
msgid "Show archived books"
msgstr "Hiển thị các quyển sách được sao lưu"

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:781
msgid ""
"Archived books are listed on the device but need to be downloaded to read. "
"Use this option to show these books and match them with books in the calibre"
" library."
msgstr "Các quyển sách được sao lưu được hiển thị trên thiết bị nhưng cần phải được tải về để đọc. Sử dụng tùy chọn này để hiển thị các quyển sách đó và gắn thông tin của quyển sách với các quyển tương tự khác trong thư viện calibre."

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:814
msgid "Advanced options"
msgstr ""

#: /__w/calibre/calibre/src/calibre/devices/kobo/kobotouch_config.py:823
msgid ""
"Kobo routinely updates the firmware and the database version. With this "
"option calibre will attempt to perform full read-write functionality - Here "
"be Dragons!! Enable only if you are comfortable with restoring your kobo to "
"factory defaults and testing software. This driver supports firmware V2.x.x "
"and DBVersion up to "
msgstr ""

