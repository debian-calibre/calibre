#: /__w/calibre/calibre/src/calibre/gui2/tweak_book/editor/themes.py:504
#, python-brace-format
msgid ""
"<h2>Creating a custom theme</h2>\n"
"\n"
"<p id=\"attribute\" lang=\"und\">You can create a custom syntax highlighting theme, with your own colors and font styles. The most important types of highlighting rules are described below. Note that not every rule supports every kind of customization, for example, changing font or underline styles for the <code>Cursor</code> rule does not have any effect as that rule is used only for the color of the blinking cursor.</p>\n"
"\n"
"<p>As you make changes to your theme on the left, the changes will be reflected live in this panel.</p>\n"
"\n"
"<p xml:lang=\"und\">\n"
"{Normal}\n"
"    The most important rule. Sets the foreground and background colors for the     editor as well as the style of \"normal\" text, that is, text that does not match any special syntax.\n"
"\n"
"{Visual}\n"
"    Defines the colors for text selected by the mouse.\n"
"\n"
"{CursorLine}\n"
"    Defines the color for the line containing the cursor.\n"
"\n"
"{LineNr}\n"
"    Defines the colors for the line numbers on the left.\n"
"\n"
"{MatchParen}\n"
"    Defines the colors for matching tags in HTML and matching\n"
"    braces in CSS.\n"
"\n"
"{Function}\n"
"    Used for highlighting tags in HTML\n"
"\n"
"{Type}\n"
"    Used for highlighting attributes in HTML\n"
"\n"
"{Statement}\n"
"    Tag names in HTML\n"
"\n"
"{Constant}\n"
"    Namespace prefixes in XML and constants in CSS\n"
"\n"
"{SpecialCharacter}\n"
"    Non{endash}breaking{nbsp}spaces/hyphens in HTML\n"
"\n"
"{Error}\n"
"    Syntax errors such as <this <>\n"
"\n"
"{SpellError}\n"
"    Misspelled words such as <span lang=\"en\">thisword</span>\n"
"\n"
"{Comment}\n"
"    Comments like <!-- this one -->\n"
"\n"
"</p>\n"
"\n"
"<style type=\"text/css\">\n"
"/* Some CSS so you can see how the highlighting rules affect it */\n"
"\n"
"p.someclass {{\n"
"    font-family: serif;\n"
"    font-size: 12px;\n"
"    line-height: 1.2;\n"
"}}\n"
