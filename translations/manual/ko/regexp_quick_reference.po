msgid "``?!``"
msgstr "``?!``"

#: ../../../__w/calibre/calibre/manual/regexp_quick_reference.rst:196
msgid "Negative lookahead (to be placed after the selection)"
msgstr "부정적 룩어헤드 (선택 뒤에 놓음)"

#: ../../../__w/calibre/calibre/manual/regexp_quick_reference.rst:199
msgid "``?<=``"
msgstr "``?<=``"

